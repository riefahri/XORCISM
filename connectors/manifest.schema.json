{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://xorcism/connectors/manifest.schema.json",
  "title": "XORCISM Connector Manifest",
  "type": "object",
  "required": ["id", "name", "type"],
  "description": "tool-runner connectors use command+parser; import connectors use run.",
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_-]+$" },
    "name": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["tool-runner", "enrichment", "import", "export"]
    },
    "category": { "type": "string" },
    "description": { "type": "string" },
    "binary": { "type": "string", "description": "executable resolved on PATH" },
    "intrusive": { "type": "boolean", "default": false },
    "permission": { "type": "string", "description": "RBAC permission key" },
    "parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "pattern": "^[a-zA-Z0-9_]+$" },
          "type": {
            "type": "string",
            "enum": ["string", "int", "bool", "enum", "target", "url", "file"]
          },
          "required": { "type": "boolean", "default": false },
          "default": {},
          "values": { "type": "array", "description": "allowlist for enum" },
          "min": { "type": "number" },
          "max": { "type": "number" },
          "pattern": { "type": "string", "description": "regex for string" },
          "help": { "type": "string" }
        }
      }
    },
    "command": {
      "type": "array",
      "items": { "type": "string" },
      "description": "argv template; {{param}}, {{outfile}}, {{workdir}} substituted with validated values (no shell)"
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["file", "stdout"] },
        "ext": { "type": "string" }
      }
    },
    "parser": { "type": "string", "description": "python parser module (parse(path_or_text, params))" },
    "run": { "type": "string", "description": "import connectors: python module exposing run(params, workdir) -> normalized result" },
    "mapping": { "type": "string", "description": "named import mapping into XORCISM" }
  }
}
