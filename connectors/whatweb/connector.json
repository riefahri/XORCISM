{
  "id": "whatweb",
  "name": "WhatWeb — Web technology fingerprint",
  "type": "tool-runner",
  "category": "web",
  "description": "Identification des technologies web (serveur, frameworks, CMS…). Importe les technos en CPE liés à l'asset.",
  "binary": "whatweb",
  "intrusive": true,
  "permission": "connector:whatweb",
  "parameters": [
    { "name": "target", "type": "target", "required": true, "help": "URL ou hôte (dans le périmètre)" },
    { "name": "aggression", "type": "enum", "values": ["1", "3"], "default": "1", "help": "1=passif, 3=agressif" }
  ],
  "command": ["whatweb", "-a", "{{aggression}}", "--log-json={{outfile}}", "{{target}}"],
  "output": { "kind": "file", "ext": "json" },
  "parser": "parse_whatweb.py",
  "mapping": "whatweb"
}
