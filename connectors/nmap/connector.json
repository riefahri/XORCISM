{
  "id": "nmap",
  "name": "Nmap — Network & service scan",
  "type": "tool-runner",
  "category": "recon",
  "description": "Découverte d'hôtes, ports, services, versions, OS et CPE. Importe les résultats dans ASSET / services / CPE.",
  "binary": "nmap",
  "intrusive": true,
  "permission": "connector:nmap",
  "parameters": [
    { "name": "target", "type": "target", "required": true, "help": "hôte, plage ou CIDR (doit être dans le périmètre autorisé)" },
    { "name": "ports", "type": "string", "default": "1-1000", "pattern": "^[0-9,\\-]+$", "help": "ex. 22,80,443 ou 1-1024" },
    { "name": "scan", "type": "enum", "values": ["-sS", "-sT", "-sV", "-A"], "default": "-sV", "help": "type de scan" },
    { "name": "timing", "type": "enum", "values": ["-T2", "-T3", "-T4"], "default": "-T3" },
    { "name": "os_detect", "type": "bool", "default": false, "help": "détection d'OS (-O, nécessite des privilèges)" }
  ],
  "command": ["nmap", "{{scan}}", "{{timing}}", "-p", "{{ports}}", "-oX", "{{outfile}}", "{{target}}"],
  "output": { "kind": "file", "ext": "xml" },
  "parser": "parse_nmap.py",
  "mapping": "nmap"
}
