{
  "id": "nuclei",
  "name": "Nuclei — Template-based vulnerability scan",
  "type": "tool-runner",
  "category": "vuln",
  "description": "Scan de vulnérabilités piloté par templates (ProjectDiscovery). Importe les findings dans VULNERABILITY / ASSETVULNERABILITY.",
  "binary": "nuclei",
  "intrusive": true,
  "permission": "connector:nuclei",
  "parameters": [
    { "name": "target", "type": "target", "required": true, "help": "URL ou hôte cible (dans le périmètre autorisé)" },
    { "name": "severity", "type": "enum", "values": ["info,low,medium,high,critical", "medium,high,critical", "high,critical", "critical"], "default": "medium,high,critical", "help": "niveaux de sévérité à inclure" },
    { "name": "rate_limit", "type": "int", "default": 150, "min": 1, "max": 1000, "help": "requêtes/seconde" },
    { "name": "timeout", "type": "int", "default": 10, "min": 1, "max": 60, "help": "timeout par requête (s)" }
  ],
  "command": ["nuclei", "-target", "{{target}}", "-severity", "{{severity}}", "-rate-limit", "{{rate_limit}}", "-timeout", "{{timeout}}", "-jsonl", "-silent", "-output", "{{outfile}}"],
  "output": { "kind": "file", "ext": "jsonl" },
  "parser": "parse_nuclei.py",
  "mapping": "nuclei"
}
