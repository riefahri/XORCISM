{
  "id": "sqlmap",
  "name": "sqlmap — SQL injection",
  "type": "tool-runner",
  "category": "web",
  "description": "Détection d'injections SQL. Chaque point d'injection est importé en VULNERABILITY liée à l'asset cible.",
  "binary": "sqlmap",
  "intrusive": true,
  "permission": "connector:sqlmap",
  "parameters": [
    { "name": "target", "type": "url", "required": true, "help": "URL à tester (ex. http://app.lab/item?id=1)" },
    { "name": "level", "type": "enum", "values": ["1", "2", "3", "4", "5"], "default": "1", "help": "Profondeur des tests" },
    { "name": "risk", "type": "enum", "values": ["1", "2", "3"], "default": "1", "help": "Niveau de risque des payloads" }
  ],
  "command": ["sqlmap", "-u", "{{target}}", "--batch", "--level", "{{level}}", "--risk", "{{risk}}", "--flush-session", "--disable-coloring"],
  "output": { "kind": "stdout" },
  "parser": "parse_sqlmap.py",
  "mapping": "sqlmap"
}
