{
  "id": "nessus",
  "name": "Tenable Nessus — import .nessus",
  "type": "import",
  "category": "vuln-scanner",
  "description": "Importe un fichier .nessus (NessusClientData_v2). Hôtes → ASSET, findings → VULNERABILITY (CVE ou Nessus:pluginID) + liens.",
  "intrusive": false,
  "permission": "connector:nessus",
  "run": "run.py",
  "mapping": "nessus",
  "parameters": [
    { "name": "file", "type": "file", "required": true, "help": "Chemin du fichier .nessus (sur le worker)" },
    { "name": "min_severity", "type": "enum", "values": ["0", "1", "2", "3", "4"], "default": "1", "help": "Severité minimale (0=info … 4=critique)" }
  ]
}
