{
  "name": "xorcism-ts",
  "version": "1.5.0-beta.1",
  "description": "XORCISM Database Explorer - TypeScript/Node.js",
  "main": "dist/server/index.js",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "build:server": "tsc -p tsconfig.server.json",
    "build:client": "node esbuild.config.js",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server/index.js",
    "dev": "concurrently \"tsc -p tsconfig.server.json --watch\" \"nodemon --watch dist/server dist/server/index.js\" \"node esbuild.config.js --watch\""
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "express": "^4.18.3",
    "express-async-errors": "^3.1.1",
    "js-yaml": "^4.2.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.5",
    "@types/pdf-parse": "^1.1.5",
    "concurrently": "^8.2.2",
    "esbuild": "^0.20.1",
    "nodemon": "^3.0.3",
    "typescript": "^5.3.3"
  }
}
